{
  "type": "module",
  "name": "kitsap-jail-roster",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "postinstall": "node -e \"if(process.env.NODE_ENV==='production'){const fs=require('fs');const path=require('path');const src=path.join(process.cwd(),'frontend','dist');const dest=path.join(process.env.STORAGE_DIR||'./data','frontend','dist');fs.mkdirSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});}\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "express": "^4.18.2",
    "node-cron": "^4.2.1"
  }
}